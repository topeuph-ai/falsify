docs/assets/v2/_build/
docs/assets/v2/_frames/
docs/assets/v2/scene_*.mp4
docs/assets/v2/scene_*_first.png
docs/assets/v2/scene_*_last.png
docs/assets/v2/radar_*.mp4
docs/assets/v2/radar_*.webm
docs/assets/v2/radar_*_first.png
docs/assets/v2/radar_*_last.png
