# Falsification Engine runtime artifacts
# (we intentionally do NOT ignore .falsify/ entirely — spec.yaml
# and spec.lock.json are committed per-claim; per-run directories,
# the latest-run pointer, and the regenerated verdict are not.)
.falsify/*/runs/
.falsify/cache/
*.falsify.log

# Dogfood / run artifacts (regenerated by falsify run; not checkpointed)
.falsify/*/latest_run
.falsify/*/verdict.json

# Git hook backups created by `falsify hook install`
.git/hooks/commit-msg.bak.*

# Demo recording venv + asciinema backups
.venv-demo/
.venv/
*.cast.bak

# Video production artifacts (not source — rebuilt from scripts/)
docs/assets/*.mp3
docs/assets/*.wav
docs/assets/frames_*/
docs/assets/vo_*.mp3

